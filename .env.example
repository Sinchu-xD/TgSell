# ── Core ──────────────────────────────────────────────────────────────────────
BOT_TOKEN=
BOT_USERNAME=YourBotUsername        # without @  — used for return URLs
API_ID=
API_HASH=
OWNER_IDS=                          # comma-separated Telegram IDs

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tgstore

# ── Cashfree ──────────────────────────────────────────────────────────────────
CASHFREE_APP_ID=
CASHFREE_SECRET=
CASHFREE_ENV=production             # sandbox | production

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── OxaPay (https://oxapay.com) ───────────────────────────────────────────────
OXAPAY_MERCHANT_API_KEY=

# ── Heleket (https://heleket.com) ─────────────────────────────────────────────
HELEKET_MERCHANT_ID=
HELEKET_API_KEY=
HELEKET_CALLBACK_URL=               # e.g. https://yourdomain.com/heleket/webhook

# ── Webhook Server ────────────────────────────────────────────────────────────
WEBHOOK_PORT=8001
